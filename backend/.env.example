# Port for the Rust backend to run on
PORT=8080

# Cloudflare R2 Credentials
# Get your Account ID from the Cloudflare Dashboard URL or Overview page
R2_ACCOUNT_ID=your_cloudflare_account_id

# Create these in Cloudflare Dashboard -> R2 -> Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# The name of the bucket you created in Cloudflare R2
R2_BUCKET_NAME=your_r2_bucket_name

# Google OAuth2 Settings
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
ALLOWED_EMAIL=admin@example.com

# CORS allowed origins (comma-separated for Vercel + local development)
ALLOWED_ORIGIN=http://localhost:5173
